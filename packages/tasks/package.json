{
	"name": "@xtarterize/tasks",
	"version": "1.13.8",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "vp pack",
		"dev": "vp pack --watch",
		"gen:biome-types": "node scripts/gen-biome-types.mjs",
		"postinstall": "node scripts/gen-biome-types.mjs",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@xtarterize/core": "workspace:*",
		"@xtarterize/patchers": "workspace:*",
		"effect": "catalog:",
		"json5": "catalog:",
		"magicast": "catalog:",
		"nypm": "catalog:",
		"pathe": "catalog:",
		"tinyexec": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/node": "catalog:",
		"json-schema-to-typescript": "^15.0.4",
		"oxlint": "^1.63.0",
		"typescript": "catalog:",
		"vite-plus": "catalog:"
	}
}
