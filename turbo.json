{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build", "typecheck"],
			"outputs": ["dist/**"]
		},
		"@xtarter/create#build": {
			"outputs": [],
			"cache": false
		},
		"dev": {
			"persistent": true,
			"cache": false
		},
		"typecheck": {
			"dependsOn": ["^build"]
		},
		"//#lint": {
			"inputs": ["biome.json", "apps/", "packages/"]
		},
		"//#verify:shebangs": {
			"dependsOn": ["^build"]
		},
		"//#test": {
			"dependsOn": [
				"^build",
				"@xtarterize/core#build",
				"@xtarterize/patchers#build",
				"@xtarterize/tasks#build",
				"create-xtarter-app#build"
			],
			"inputs": ["vitest.config.ts", "test/"]
		}
	}
}
