{
	"name": "xtarter",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"contributors:add": "all-contributors add",
		"contributors:generate": "all-contributors generate",
		"contributors:check": "all-contributors check",
		"build": "turbo run build",
		"build:cli": "turbo run build --filter=!@xtarterize/docs",
		"verify:shebangs": "node scripts/verify-shebangs.mjs",
		"dev": "turbo run dev",
		"test": "vp test",
		"test:run": "vp test run",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"typecheck": "turbo run typecheck",
		"check": "turbo run typecheck build lint test verify:shebangs",
		"docs:dev": "pnpm --filter @xtarterize/docs dev",
		"docs:build": "pnpm --filter @xtarterize/docs build",
		"docs:preview": "pnpm --filter @xtarterize/docs preview",
		"xt:dev": "pnpm --filter xtarterize dev",
		"xt:build": "pnpm --filter xtarterize build",
		"cxa:dev": "pnpm --filter create-xtarter-app dev",
		"cxa:build": "pnpm --filter create-xtarter-app build",
		"cxa:typecheck": "pnpm --filter create-xtarter-app typecheck",
		"cxa:test": "pnpm --filter create-xtarter-app test",
		"up-interactive": "pnpm up -i -r",
		"up-latest": "pnpm up-interactive -L",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "changeset publish",
		"prepare": "vp config"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@types/node": "catalog:",
		"all-contributors-cli": "^6.26.1",
		"turbo": "^2.10.0",
		"vite-plus": "catalog:"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "24.16.0",
			"onFail": "download"
		}
	},
	"packageManager": "pnpm@11.9.0"
}
