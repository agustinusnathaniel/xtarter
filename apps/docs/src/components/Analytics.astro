---
// biome-ignore lint/correctness/noUnusedVariables: used in template below
const umamiSrc = import.meta.env.UMAMI_SRC
// biome-ignore lint/correctness/noUnusedVariables: used in template below
const umamiWebsiteId = import.meta.env.UMAMI_WEBSITE_ID
---

{umamiSrc && umamiWebsiteId && (
  <script defer src={umamiSrc} data-website-id={umamiWebsiteId} data-performance="true" />
)}
