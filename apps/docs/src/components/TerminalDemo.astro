---
// Terminal demo showing a multi-step CLI workflow:
// step 1: npx xtarterize init --dry-run  (shows conformance plan)
// step 2: npx xtarterize check            (shows status)
// step 3: npx xtarterize diff             (shows planned changes)
// step 4: npx xtarterize sync             (applies with backup)
---

<div class="terminal-demo">
  <div class="terminal-header">
    <span class="terminal-dot red"></span>
    <span class="terminal-dot yellow"></span>
    <span class="terminal-dot green"></span>
    <span class="terminal-title">xtarterize — dry-run</span>
  </div>
  <div class="terminal-body" id="terminal-body">
    <!-- Step 1: init --dry-run -->
    <div class="line-group" style="--delay: 0s">
      <div class="terminal-line cmd-line" style="--char-delay: 0.3s">
        <span class="prompt">❯</span>
        <span class="command typed">npx xtarterize init --dry-run</span>
      </div>
      <div class="terminal-line output scan-line" style="--line-delay: 2.8s">
        <span class="spin">●</span> Scanning project...
      </div>
      <div class="terminal-line output result" style="--line-delay: 4.2s">
        <span class="label-detect">detected</span>
        <span class="dim">react 19 · vite 8 · typescript 5.8 · pnpm 10</span>
      </div>
      <div class="terminal-line output result" style="--line-delay: 5.2s">
        <span class="label-plan">plan</span>
        <span class="dim">12 tasks · 8 files</span>
      </div>
    </div>

    <!-- Step 2: conformance table -->
    <div class="line-group" style="--delay: 6s">
      <div class="terminal-line output section-header" style="--line-delay: 0.2s">
        <span class="bold accent">Conformance plan</span>
      </div>
      <div class="terminal-line output table-header" style="--line-delay: 0.5s">
        <span class="dim">Status  Task                    Group</span>
      </div>
      <div class="terminal-line output" style="--line-delay: 0.8s">
        <span class="dim">──────────────────────────────────────────────</span>
      </div>
      <div class="terminal-line output table-row" style="--line-delay: 1.1s">
        <span class="success">+</span>  Biome (lint + format)      Linting
      </div>
      <div class="terminal-line output table-row" style="--line-delay: 1.5s">
        <span class="warning">~</span>  tsconfig — strict: true     TypeScript
      </div>
      <div class="terminal-line output table-row" style="--line-delay: 1.9s">
        <span class="success">+</span>  GitHub Actions CI          CI/CD
      </div>
      <div class="terminal-line output table-row" style="--line-delay: 2.3s">
        <span class="success">+</span>  VS Code settings + ext.     Editor
      </div>
      <div class="terminal-line output table-row" style="--line-delay: 2.7s">
        <span class="success">+</span>  Agent skills                AI
      </div>
      <div class="terminal-line output table-row" style="--line-delay: 3.1s">
        <span class="success">+</span>  vite-plugin-checker         Vite
      </div>
    </div>

    <!-- Step 3: diff summary -->
    <div class="line-group" style="--delay: 10s">
      <div class="terminal-line cmd-line" style="--char-delay: 0.3s">
        <span class="prompt">❯</span>
        <span class="command typed">npx xtarterize diff</span>
      </div>
      <div class="terminal-line output result" style="--line-delay: 2s">
        <span class="label-info">info</span>
        <span class="dim">Showing diffs for 8 files</span>
      </div>
      <div class="terminal-line output result" style="--line-delay: 2.8s">
        <span class="success">+</span>  <span class="dim">biome.json</span>
        <span class="file-diff">+47 lines</span>
      </div>
      <div class="terminal-line output result" style="--line-delay: 3.6s">
        <span class="warning">~</span>  <span class="dim">tsconfig.json</span>
        <span class="file-diff">+3 / -1 lines</span>
      </div>
      <div class="terminal-line output result" style="--line-delay: 4.4s">
        <span class="success">+</span>  <span class="dim">.github/workflows/ci.yml</span>
      </div>
      <div class="terminal-line output result" style="--line-delay: 5.2s">
        <span class="success">+</span>  <span class="dim">.vscode/extensions.json</span>
      </div>
      <div class="terminal-line output result" style="--line-delay: 6s">
        <span class="label-safety">backup</span>
        <span class="dim">Originals saved to</span>
        <span class="dim accent">.xtarterize/backups/</span>
      </div>
    </div>

    <!-- Final cursor -->
    <div class="line-group" style="--delay: 17s">
      <div class="terminal-line">
        <span class="prompt">❯</span>
        <span class="cursor">_</span>
      </div>
    </div>
  </div>
</div>

<style>
  /* ---- Terminal container ---- */
  .terminal-demo {
    width: 100%;
    max-width: 780px;
    margin: 0 auto 3rem;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--sl-color-gray-5);
    box-shadow:
      0 24px 80px rgba(0, 0, 0, 0.35),
      0 0 0 1px rgba(255, 255, 255, 0.04) inset;
    transition: box-shadow 0.3s ease;
    position: relative;
  }

  .terminal-demo::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 14px;
    padding: 1px;
    background: linear-gradient(
      135deg,
      transparent 0%,
      var(--sl-color-accent-low) 50%,
      transparent 100%
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    opacity: 0.3;
  }

  /* ---- Terminal header ---- */
  .terminal-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 18px;
    background: var(--sl-color-gray-8, #1a1a1a);
    border-bottom: 1px solid var(--sl-color-gray-6);
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .terminal-dot.red    { background: #ff5f57; }
  .terminal-dot.yellow { background: #ffbd2e; }
  .terminal-dot.green  { background: #28c840; }

  .terminal-title {
    margin-left: auto;
    font-size: 0.8rem;
    color: var(--sl-color-gray-4);
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  /* ---- Terminal body ---- */
  .terminal-body {
    padding: 1.5rem 1.75rem;
    background: var(--sl-color-gray-9, #0d0d0d);
    font-family: var(--font-mono);
    font-size: 0.87rem;
    line-height: 1.85;
    overflow-x: auto;
  }

  /* ---- Line groups (sequenced via animation-delay) ---- */
  .line-group {
    opacity: 0;
    animation: fadeIn 0.3s ease forwards;
    animation-delay: var(--delay);
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  /* ---- General line styling ---- */
  .terminal-line {
    white-space: pre;
  }

  .terminal-line .prompt {
    color: var(--sl-color-accent);
    margin-right: 0.5rem;
    font-weight: 700;
  }

  .terminal-line .command {
    color: var(--sl-color-white);
  }

  /* ---- Typing animation ---- */
  .typed {
    display: inline;
    overflow: hidden;
    white-space: nowrap;
    animation: typing 0.8s steps(40, end) forwards;
    width: 0;
  }

  @keyframes typing {
    from { width: 0; }
    to { width: 100%; }
  }

  /* ---- Scan/spin animation ---- */
  .spin {
    display: inline-block;
    animation: spin 1s linear infinite;
    margin-right: 0.4rem;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* ---- Output lines with staggered reveal ---- */
  .terminal-line.output {
    opacity: 0;
    animation: revealLine 0.25s ease forwards;
    animation-delay: var(--line-delay, 0s);
  }

  @keyframes revealLine {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .terminal-line.cmd-line {
    opacity: 0;
    animation: revealLine 0.3s ease forwards;
    animation-delay: var(--line-delay, 0s);
  }

  /* ---- Status badges (inline) ---- */
  .label-detect,
  .label-plan,
  .label-info,
  .label-safety {
    display: inline-flex;
    align-items: center;
    padding: 0 0.45rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-right: 0.5rem;
    line-height: 1.6;
  }

  .label-detect { background: #6366f133; color: #818cf8; }
  .label-plan   { background: #a855f733; color: #c084fc; }
  .label-info   { background: #0ea5e933; color: #38bdf8; }
  .label-safety { background: #22c55e33; color: #4ade80; }

  /* ---- Symbol colors ---- */
  .success { color: #22c55e; margin-right: 0.5rem; }
  .warning { color: #f59e0b; margin-right: 0.5rem; }
  .dim     { color: var(--sl-color-gray-4); }
  .bold    { font-weight: 700; }
  .accent  { color: var(--sl-color-accent); }

  .terminal-line .file-diff {
    color: var(--sl-color-gray-2);
    font-size: 0.78rem;
    margin-left: 0.75rem;
  }

  /* ---- Section header ---- */
  .section-header {
    margin-top: 0.25rem;
  }

  /* ---- Cursor ---- */
  .cursor {
    animation: blink 1s step-end infinite;
    color: var(--sl-color-accent);
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0; }
  }

  /* ---- Table styling for conformance plan ---- */
  .terminal-line .accent {
    color: var(--sl-color-accent);
  }

  .table-row {
    padding-left: 1.5ch;
  }

  /* ---- Mobile ---- */
  @media (max-width: 640px) {
    .terminal-demo {
      max-width: 100%;
      margin: 0 auto 2rem;
      border-radius: 10px;
    }

    .terminal-body {
      font-size: 0.68rem;
      padding: 1rem;
      line-height: 1.7;
    }

    .terminal-header {
      padding: 10px 14px;
    }

    .terminal-dot {
      width: 10px;
      height: 10px;
    }
  }
</style>
