---
import type { StarlightRouteData } from '@astrojs/starlight/route-data'

interface Props {
	entry: StarlightRouteData['sidebar'][number]
	currentPath: string
}

const { entry, currentPath } = Astro.props
---

{
    entry.type === 'link' ? (
        <a href={entry.href} class="drawer-link" data-active={currentPath === entry.href} {...entry.attrs}>
            {entry.label}
            {entry.badge && <span class="badge">{entry.badge.text}</span>}
        </a>
    ) : (
        <div class="drawer-group">
            <span class="drawer-group-label">{entry.label}</span>
            <div class="drawer-children">
                {
                    entry.entries.map((child) => (
                        <Astro.self entry={child} currentPath={currentPath} />
                    ))
                }
            </div>
        </div>
    )
}

<style>
    .drawer-group {
        display: flex;
        flex-direction: column;
        gap: calc(var(--spacing) * 2);
    }
    .drawer-group + .drawer-group {
        margin-top: calc(var(--spacing) * 2);
    }
    .drawer-group-label {
        font-weight: 500;
        font-size: 0.875rem;
        color: var(--foreground);
    }
    .drawer-children {
        display: flex;
        flex-direction: column;
        gap: calc(var(--spacing) * 2);
        padding-left: calc(var(--spacing) * 3);
    }
    .drawer-link {
        font-size: 1rem;
        line-height: 1.2rem;
        color: var(--muted-foreground);
        text-decoration: inherit;
    }
    .drawer-link[data-active='true'] {
        color: var(--foreground);
        font-weight: 500;
    }
    .badge {
        padding-top: calc(var(--spacing) * 0.5);
        padding-bottom: calc(var(--spacing) * 0.5);
        padding-left: calc(var(--spacing) * 1.5);
        padding-right: calc(var(--spacing) * 1.5);
        margin-left: calc(var(--spacing) * 2);
        border-radius: 0.375rem;
        font-size: 0.75rem;
        line-height: 1rem;
        font-weight: 400;
        line-height: 1;
        text-decoration: none;
        background: #adfa1d;
        color: #000000;
    }
</style>
