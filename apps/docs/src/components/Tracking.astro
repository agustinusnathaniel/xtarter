---
// Centralized Umami event tracking via event delegation and attribute-based tracking.
// data-umami-event attributes are used where we control the HTML (more reliable for navigation).
// JS handlers cover elements we can't annotate (hero CTAs, theme, search, social links).
---

<script>
function track(event: string, data?: Record<string, string>) {
  window.umami?.track(event, data);
}

function getText(el: Element | null): string {
  return (el?.textContent ?? '').trim();
}

function getHref(el: Element | null): string {
  return (el as HTMLAnchorElement)?.href ?? '';
}

const TRACKED_EXTERNAL_DOMAINS = [
  'github.com',
  'biomejs.dev',
  'typescriptlang.org',
  'vitejs.dev',
  'react.dev',
  'skills.sh',
  'astro.build',
  'viteplus.dev',
];

function isTrackedDomain(hostname: string): boolean {
  return TRACKED_EXTERNAL_DOMAINS.some(d => hostname === d || hostname.endsWith('.' + d));
}

document.addEventListener('click', (e) => {
  const target = e.target as HTMLElement;

  // Hero CTA clicks (YAML frontmatter - can't add data attributes)
  const heroLink = target.closest('.hero a');
  if (heroLink) {
    const text = getText(heroLink);
    if (text.includes('Browse Templates')) track('hero_cta_browse');
    else if (text.includes('Get Started')) track('hero_cta_get_started');
    else if (text.includes('View CLI Reference')) track('hero_cta_cli_reference');
    return;
  }

  // Page action: copy markdown button
  const actionBtn = target.closest('.action-button');
  if (actionBtn) {
    const text = getText(actionBtn);
    if (text.includes('Copy')) track('page_action', { action: 'copy' });
    return;
  }

  // Page action: share / AI prompt dropdown items
  const dropdownItem = target.closest('.dropdown-item');
  if (dropdownItem) {
    const text = getText(dropdownItem);
    if (text.includes('Share')) track('page_action', { action: 'share' });
    else if (text.includes('Open')) track('page_action', { action: 'ai_prompt' });
    return;
  }

  // Social icon links (header - starlight SocialIcons renders <a rel="me">)
  const socialLink = target.closest('a[rel="me"]');
  if (socialLink) {
    const href = getHref(socialLink);
    const domain = href.includes('github.com') ? 'github' : 'other';
    track('social_click', { domain });
    return;
  }

  // Search opened
  const searchBtn = target.closest('button[data-open-modal]');
  if (searchBtn) {
    track('search_open');
    return;
  }

  // Search result clicked (Pagefind)
  const searchResult = target.closest('.pagefind-ui__result-link');
  if (searchResult) {
    const text = getText(searchResult);
    track('search_result_click', { title: text.slice(0, 120) });
    return;
  }

  // External link clicks to tracked domains (skip links already handled by data-umami-event)
  const extLink = target.closest('a[href^="http"]');
  if (extLink && !extLink.hasAttribute('data-umami-event')) {
    const href = getHref(extLink);
    try {
      const { hostname, pathname } = new URL(href);
      if (isTrackedDomain(hostname)) {
        track('external_link', { domain: hostname, path: pathname });
      }
    } catch {
      // invalid URL, skip
    }
  }
});

// Theme toggle (select change event)
document.addEventListener('change', (e) => {
  const select = (e.target as HTMLElement).closest('starlight-theme-select select') as HTMLSelectElement | null;
  if (select?.value) {
    track('theme_toggle', { theme: select.value });
  }
});
</script>
