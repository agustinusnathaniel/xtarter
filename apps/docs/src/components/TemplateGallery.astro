---
interface Repo {
	name: string
	full_name: string
	description: string | null
	homepage: string | null
	html_url: string
	stargazers_count: number
	topics: string[]
	is_template: boolean
	archived: boolean
}

interface Template {
	name: string
	description: string
	url: string
	stars: number
	topics: string[]
	archived: boolean
}

const GITHUB_USER = 'agustinusnathaniel'
const EXCLUDED_TOPICS = [
	'boilerplate',
	'boilerplate-template',
	'nextjs-boilerplate',
	'nextjs-template',
	'nextjs-starter',
	'pwa',
	'react',
	'react-typescript',
	'react-typescript-boilerplate',
	'remix-boilerplate',
	'remix-run',
	'remix-template',
	'starter-template',
	'sveltekit-template',
	'sveltekit-tailwind-template',
	'sveltekit-tailwindcss',
	'svelte',
	'tailwind',
	'template',
	'typescript',
]

function filterTopics(topics: string[]): string[] {
	return topics.filter((t) => !EXCLUDED_TOPICS.includes(t))
}

// biome-ignore lint/correctness/noUnusedVariables: used in template below
let templates: Template[] = []

try {
	const res = await fetch(
		`https://api.github.com/users/${GITHUB_USER}/repos?type=owner&per_page=200&sort=full_name`,
	)
	if (res.ok) {
		const repos: Repo[] = await res.json()
		templates = repos
			.filter((r) => r.is_template)
			.sort((a, b) => b.stargazers_count - a.stargazers_count)
			.map((r) => ({
				name: r.name,
				description: r.description ?? '',
				url: r.homepage ?? r.html_url,
				stars: r.stargazers_count,
				topics: filterTopics(r.topics).sort(),
				archived: r.archived,
			}))
	}
} catch {
	// Silently fall back to empty — shows nothing if GitHub is unreachable
}
---

{
  templates.length === 0 ? (
    <p class="no-templates">Unable to load templates. <a href={`https://github.com/${GITHUB_USER}?tab=repositories&q=&type=source`} target="_blank" rel="noopener noreferrer" data-umami-event="github_browse_click">Browse on GitHub →</a></p>
  ) : (
    <div class="template-gallery">
      {templates.map((t) => (
        <a href={t.url} target="_blank" rel="noopener noreferrer" class="template-card" data-umami-event="template_click" data-umami-event-template_name={t.name} data-umami-event-stars={String(t.stars)}>
          <div class="template-header">
            <h3 class="template-name">{t.name}</h3>
            <span class="template-stars">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {t.stars}
            </span>
          </div>
          <p class="template-desc">{t.description}</p>
          <div class="template-topics">
            {t.topics.map((topic) => <span class="template-topic">{topic}</span>)}
          </div>
          {t.archived && <span class="template-archived">archived</span>}
        </a>
      ))}
    </div>
  )
}

<style>
.template-gallery {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
  margin: 2rem 0;
}

.template-card {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding: 1.5rem;
  border-radius: 10px;
  border: 1px solid var(--sl-color-gray-5);
  background: var(--sl-color-gray-6);
  text-decoration: none;
  color: inherit;
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.template-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  border-color: var(--sl-color-accent-low);
}

.template-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 0.75rem;
}

.template-name {
  margin: 0;
  font-size: 1.05rem;
  font-weight: 600;
  font-family: var(--font-sans);
  letter-spacing: -0.01em;
}

.template-stars {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.85rem;
  color: var(--sl-color-gray-2);
  white-space: nowrap;
  flex-shrink: 0;
}

.template-stars svg {
  color: var(--sl-color-accent);
}

.template-desc {
  margin: 0;
  font-size: 0.9rem;
  color: var(--sl-color-gray-2);
  line-height: 1.5;
  flex: 1;
}

.template-topics {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.template-topic {
  font-size: 0.75rem;
  padding: 0.15rem 0.6rem;
  border-radius: 6px;
  background: var(--sl-color-accent-low);
  color: #fff;
}

.template-archived {
  font-size: 0.75rem;
  padding: 0.15rem 0.6rem;
  border-radius: 6px;
  background: #dc262633;
  color: #dc2626;
  align-self: flex-start;
}

.no-templates {
  text-align: center;
  padding: 2rem;
  color: var(--sl-color-gray-2);
}

@media (max-width: 640px) {
  .template-gallery {
    grid-template-columns: 1fr;
  }
}
</style>
