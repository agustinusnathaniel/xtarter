{
	"name": "xtarterize",
	"version": "1.15.2",
	"description": "Automated project setup and configuration scaffolding",
	"keywords": [
		"boilerplate",
		"cli",
		"project-setup",
		"scaffold",
		"starter",
		"template"
	],
	"homepage": "https://xtarter.sznm.dev/xtarterize",
	"bugs": {
		"url": "https://github.com/agustinusnathaniel/xtarter/issues"
	},
	"license": "MIT",
	"author": "agustinusnathaniel",
	"repository": {
		"type": "git",
		"url": "https://github.com/agustinusnathaniel/xtarter",
		"directory": "apps/xtarterize"
	},
	"bin": {
		"xtarterize": "./dist/index.mjs"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "vp pack",
		"dev": "vp pack --watch",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@clack/prompts": "catalog:",
		"citty": "catalog:",
		"cli-table3": "^0.6.5",
		"jsonc-parser": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@xtarterize/core": "workspace:*",
		"@xtarterize/patchers": "workspace:*",
		"@xtarterize/tasks": "workspace:*",
		"typescript": "catalog:",
		"vite-plus": "catalog:"
	},
	"engines": {
		"node": ">=24"
	},
	"exports": {
		".": "./dist/index.mjs",
		"./package.json": "./package.json"
	},
	"inlinedDependencies": {
		"@babel/parser": "7.29.7",
		"confbox": "0.2.4",
		"consola": "3.4.2",
		"defu": "6.1.7",
		"diff": "9.0.0",
		"effect": "4.0.0-beta.91",
		"exsolve": "1.0.8",
		"json5": "2.2.3",
		"magicast": "0.5.3",
		"nypm": "0.6.7",
		"pathe": "2.0.3",
		"picocolors": "1.1.1",
		"pkg-types": "2.3.1",
		"tinyexec": "1.2.4"
	}
}
